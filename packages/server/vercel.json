{
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/**/*",
          "config/**/*",
          "prisma/generated/**/*"
        ]
      }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/src/index.ts" }
  ]
}
